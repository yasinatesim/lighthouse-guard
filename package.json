{
  "name": "lighthouse-guard",
  "version": "1.0.0",
  "description": "Stabil Lighthouse CI - Ban korumalı, retry destekli, çoklu ölçüm",
  "main": "dist/runner.js",
  "types": "dist/runner.d.ts",
  "scripts": {
    "build": "tsc && node scripts/build.mjs",
    "build:ts": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:bundle": "node scripts/__tests__/run-all.mjs",
    "test:bundle:quickstart": "node scripts/__tests__/test-quickstart.mjs",
    "test:bundle:github-actions": "node scripts/__tests__/test-github-actions.mjs",
    "test:bundle:full-workflow": "node scripts/__tests__/test-full-workflow.mjs",
    "test:bundle:local-server": "node scripts/__tests__/test-local-server.mjs"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/dashboard/**",
      "!src/action/index.ts"
    ]
  },
  "keywords": [
    "lighthouse",
    "performance",
    "ci",
    "github-actions",
    "web-vitals",
    "core-web-vitals",
    "devops",
    "retry",
    "rate-limit"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^2.1.11",
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.2.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vercel/ncc": "^0.38.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ]
}
